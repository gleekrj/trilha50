// https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  // Dentro de `src/` para o Nest emitir `dist/src/generated/...` e os imports relativos funcionarem em runtime.
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

/// Entidade persistida (espelha a tabela; alinhar com `models` no domínio quando necessário).
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
